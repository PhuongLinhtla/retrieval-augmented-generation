EMBEDDING_BACKEND=sentence_transformers
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
OLLAMA_EMBED_MODEL=nomic-embed-text

LLM_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=qwen2.5:14b-instruct-q4_K_M
OLLAMA_FALLBACK_MODEL=llama3.1:8b-instruct-q5_K_M
OLLAMA_VISION_MODEL=moondream
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.1
OLLAMA_TIMEOUT=180

CHUNK_SIZE=750
CHUNK_OVERLAP=120
PARENT_CHUNK_SIZE=2200

CHILD_CHUNK_TARGET_TOKENS=450
CHILD_CHUNK_MIN_TOKENS=200
CHILD_CHUNK_MAX_TOKENS=700
CHILD_CHUNK_OVERLAP_SENTENCES=2
PARENT_CHUNK_TARGET_TOKENS=1200
PARENT_CHUNK_MIN_TOKENS=900
PARENT_CHUNK_MAX_TOKENS=1600
PARENT_CHILD_GROUP_MIN=2
PARENT_CHILD_GROUP_MAX=4

TOP_K=3
TOP_K_DENSE=48
TOP_K_SPARSE=48
FUSION_TOP_K=96
RERANK_TOP_K=10
ANN_CANDIDATES=12
MIN_SIMILARITY=0.30
MMR_LAMBDA=0.68

USE_HYBRID_RETRIEVAL=true
USE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_BATCH_SIZE=8

LOW_CONFIDENCE_THRESHOLD=0.46
LOW_CONFIDENCE_MARGIN=0.06
LOW_CONFIDENCE_TOP_GAP=0.04

ENABLE_EVIDENCE_COMPRESSION=true
EVIDENCE_SENTENCE_MIN=15
EVIDENCE_SENTENCE_MAX=40
EVIDENCE_CHUNK_MIN=6
EVIDENCE_CHUNK_MAX=10
EVIDENCE_MIN_TOKENS=1500
EVIDENCE_MAX_TOKENS=3000
RERANKER_LOW_SCORE_THRESHOLD=0.34

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
